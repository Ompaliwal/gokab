# ==========================================================
# GoKab Root Repository (.gitignore)
# ==========================================================

# ==========================================================
# Dependencies
# ==========================================================
node_modules/
**/node_modules/

# ==========================================================
# Build Output
# ==========================================================
dist/
build/
out/
coverage/
**/dist/
**/build/
**/coverage/
*.tsbuildinfo

# ==========================================================
# Environment Variables
# ==========================================================
.env
.env.*
**/.env
**/.env.*

# Keep examples
!.env.example
!**/.env.example

# ==========================================================
# Logs
# ==========================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================================
# Runtime Files
# ==========================================================
*.pid
*.pid.lock
*.seed
*.sock

# ==========================================================
# Cache
# ==========================================================
.cache/
.parcel-cache/
.vite/
.eslintcache
.stylelintcache
.npm/
.pnpm-store/
.yarn/
.yarn/cache/
.yarn/unplugged/

# ==========================================================
# Uploads / Generated Assets
# ==========================================================
uploads/
**/uploads/
storage/
temp/
tmp/
cache/
media/

# ==========================================================
# Firebase
# ==========================================================
.firebase/
firebase-debug.log
firebase-debug.*

# Firebase Admin SDK
serviceAccountKey.json
firebase-adminsdk*.json
**/serviceAccountKey.json

# ==========================================================
# Database / Local Data
# ==========================================================
*.sqlite
*.sqlite3
*.db
*.sql
*.dump
dump.rdb
appendonly.aof

# ==========================================================
# Docker
# ==========================================================
.docker/
docker-data/

# ==========================================================
# Certificates / Secrets
# ==========================================================
*.pem
*.key
*.crt
*.csr
certs/

# ==========================================================
# IDE / Editors
# ==========================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

.idea/
*.iml

# ==========================================================
# OS Files
# ==========================================================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
Icon?
$RECYCLE.BIN/

# ==========================================================
# Temporary Files
# ==========================================================
*.tmp
*.temp
*.bak
*.orig
*.rej
*.swp
*.swo
*~

# ==========================================================
# Deployment
# ==========================================================
.vercel/
.netlify/

# ==========================================================
# Project Specific
# ==========================================================
Redigo_flutter_shell/
Redigo_driver_webview/

branch_structure.json

temp_auto_push.bat
temp_interactive_push.bat

# ==========================================================
# Archives
# ==========================================================
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# ==========================================================
# Miscellaneous
# ==========================================================
*.tgz

# ==========================================================
# Keep Important Project Files
# ==========================================================
!README.md
!LICENSE
!package.json
!package-lock.json
!pnpm-lock.yaml
!yarn.lock